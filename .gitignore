models/*.pth
!models/birdcnn_release_mit_yamnet.pth
!models/birdcnn_release_ohne_yamnet.pth

# Alte Modell-Artefakte im Root (vor models/-Umstellung) nicht versehentlich committen
/model_best.pth
/model.pth
notebooks/*.pth

